{
  "name": "MyTracker",
  "displayName": "MyTracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "ios:pod-install": "cd ios && pod install",
    "ios:build:ci": "cd ios && yarn ios:pod-install && export MAPBOX_TOKEN=${MAPBOX_TOKEN:-} && xcodebuild -workspace MyTracker.xcworkspace -scheme MyTracker -configuration Release -archivePath $PWD/build/MyTracker.xcarchive archive CODE_SIGNING_ALLOWED=NO CODE_SIGN_STYLE=Manual",
    "ci:export-ipa": "sh scripts/ci-export-ipa.sh",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.20.2",
    "@react-native-mapbox-gl/maps": "^10.5.0",
    "@react-navigation/bottom-tabs": "^6.5.7",
    "@react-navigation/native": "^6.1.7",
    "date-fns": "^2.30.0",
    "haversine-distance": "^1.1.1",
    "react": "18.3.1",
    "react-native": "0.72.4",
    "react-native-background-fetch": "^4.0.0",
    "react-native-ble-plx": "^3.0.0",
    "react-native-geolocation-service": "^5.4.0",
    "react-native-gesture-handler": "^2.12.0",
    "react-native-permissions": "^3.12.0",
    "react-native-reanimated": "^3.4.0",
    "react-native-safe-area-context": "^4.6.3",
    "react-native-screens": "^3.22.0",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-dotenv": "^4.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.3",
    "@types/react": "^18.3.3",
    "@types/react-native": "^0.72.0",
    "@types/react-test-renderer": "^18.0.0",
    "@testing-library/react-native": "^13.3.0",
    "babel-jest": "^29.6.1",
    "jest": "^29.6.1",
    "metro-react-native-babel-preset": "^0.76.9",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.5.2"
  }
}
