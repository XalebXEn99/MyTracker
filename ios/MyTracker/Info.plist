<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>
  <key>CFBundleExecutable</key>
  <string>$(EXECUTABLE_NAME)</string>
  <key>CFBundleIdentifier</key>
  <string>com.mytracker.app</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>MyTracker</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSRequiresIPhoneOS</key>
  <true/>
  <key>UIBackgroundModes</key>
  <array>
    <string>location</string>
    <string>fetch</string>
    <string>bluetooth-central</string>
  </array>
  <key>NSLocationWhenInUseUsageDescription</key>
  <string>Allow location access to display your position on the map and record walks and drives.</string>
  <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
  <string>Allow continuous tracking for background route recording and offline map downloads.</string>
  <key>NSLocationAlwaysUsageDescription</key>
  <string>Allow always-on location updates so the app can track routes while backgrounded.</string>
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>Allow Bluetooth access to detect car connections and BLE watch devices.</string>
  <key>NSBluetoothPeripheralUsageDescription</key>
  <string>Required for BLE watch scanning and accessory connection support.</string>
  <key>NSMotionUsageDescription</key>
  <string>Allow motion access for tracking activity and fitness data.</string>
  <key>NSCameraUsageDescription</key>
  <string>Camera access is required to capture photos for your memories.</string>
  <key>NSPhotoLibraryAddUsageDescription</key>
  <string>Allow saving snapshots and captured photos to the app sandbox.</string>
  <key>UILaunchStoryboardName</key>
  <string>LaunchScreen</string>
</dict>
</plist>
