* text=auto

# Force Unix line endings for all iOS/source files
ios/**/*.pbxproj text eol=lf
ios/**/*.plist text eol=lf
ios/**/*.h text eol=lf
ios/**/*.m text eol=lf
ios/**/*.swift text eol=lf
ios/Podfile text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary

