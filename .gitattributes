* text=auto

# iOS/Xcode files - always Unix line endings
*.pbxproj text eol=lf
*.pbxuser text eol=lf
*.xcworkspace/** text eol=lf
Podfile text eol=lf
*.plist text eol=lf

# Source code - always Unix line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
